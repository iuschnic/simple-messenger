              <mxPoint x="900" y="225" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="QuLFCXCf0gdW-kJHBGHE-112" value="&lt;div style=&quot;text-align: justify; font-size: 18px;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 18px;&quot;&gt;Задачи фронта:&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify; font-size: 18px;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify; font-size: 16px;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;1. Отобразить контакты (поиск по наличию contact_name в таблице Users)&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify; font-size: 16px;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify; font-size: 16px;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;2. Взаимодействие со своими данными (таблица с одной строкой (возможны&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify; font-size: 16px;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;расширения) User)&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify; font-size: 16px;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify; font-size: 16px;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;3. Отобразить список чатов (по id пользователя те чаты, где он есть находятся&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify; font-size: 16px;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;в таблице ChatsUsers,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;затем информация о чатах достаётся из таблицы Chats)&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify; font-size: 16px;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify; font-size: 16px;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;4. Посмотреть участников чата (таблица ChatsUsers, а затем данные достаются из Users)&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify; font-size: 16px;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;5. Отобразить чат (по id находится чат, затем по вторичному ключу&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot; style=&quot;font-size: 16px;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;ищутся сообщения данного чата в таблице Messenge и&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;font-family: mvCsIGRGtYPKoc7_HnId; background-color: initial;&quot;&gt;отправители этих cообщений&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font style=&quot;background-color: initial;&quot; face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;подтягиваются из таблицы Users&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: initial; font-family: mvCsIGRGtYPKoc7_HnId;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;6. Отправить сообщение&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;7. Создать чат&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;8. Удалить сообщение&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;9. Выйти из чата&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;10. Удалить участника чата, где пользователь - владелец&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;11. Добавить пользователя в контакты&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;mvCsIGRGtYPKoc7_HnId&quot;&gt;12. Добавтьь пользователя в чат&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;div style=&quot;text-align: justify; text-wrap: wrap;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 14px; text-align: left; text-wrap: wrap;&quot;&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-40" y="570" width="630" height="590" as="geometry" />
        </mxCell>
        <mxCell id="1KDI6llH6kyj1ZjW2hMJ-1" value="&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;Однострочная таблица с информацией о пользователе. Возможны раширения для нескольких аккаунтов&lt;/span&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;align=center;" parent="1" vertex="1">
          <mxGeometry x="-200" y="30" width="180" height="120" as="geometry" />
        </mxCell>
        <mxCell id="1KDI6llH6kyj1ZjW2hMJ-2" value="Таблица, используемая для отображения сообщений.&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;В случае добавления/удаления пользователя из чата передаётся соотвествующий текст&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;(&quot;вася покинул чат&quot;), а поле&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;sender_id == null.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;Права на удаление соощений есть только у отправителя и владельца чата.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;В случае удаления сообщения, оно помечается как удалённое и все сообщения которые на него ссылались отображаются как обычные сообщения.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Первичным ключом сообщения являются идентификатор чата и порядковый номер в этом чате&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Важно: при forward пользователя-отправителя может не быть в таблице пользователей, для этого в API есть метод получения информации о пользователе по его Id&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" parent="1" vertex="1">
          <mxGeometry x="200" y="-180" width="290" height="330" as="geometry" />
        </mxCell>
        <mxCell id="1KDI6llH6kyj1ZjW2hMJ-4" value="Таблица, хранящая инфорцмацию о чатах.&lt;div&gt;Version позволяет определить начиная с какого сообщения необходимо подтянуть данные из backend.&lt;/div&gt;&lt;div&gt;Type позволяет блокировать добавление новых пользователей в личные чаты.&lt;/div&gt;&lt;div&gt;LastMessageNum - номер последнего сообщения в чате&lt;/div&gt;&lt;div&gt;&amp;nbsp;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" parent="1" vertex="1">
          <mxGeometry x="670" y="-120" width="210" height="270" as="geometry" />
        </mxCell>
        <mxCell id="1KDI6llH6kyj1ZjW2hMJ-5" value="Таблица связка чатов и пользователей&lt;div&gt;LastReadMessageNum - номер последнего прочитанного сообщения данным пользователем в данном чате&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" parent="1" vertex="1">
          <mxGeometry x="1000" y="140" width="230" height="130" as="geometry" />
        </mxCell>
        <mxCell id="1KDI6llH6kyj1ZjW2hMJ-6" value="&lt;font style=&quot;font-size: 12px;&quot; face=&quot;Helvetica&quot;&gt;Таблица ассоциированных пользователей (все пользователи, находящиеся в чатах, в которых состоит текущий пользователь, для отображения сообщений).&lt;/font&gt;&lt;div style=&quot;&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;font-size: 12px;&quot;&gt;В поле C&lt;span style=&quot;text-align: left; background-color: initial;&quot;&gt;ontactName прописано имя пользователя которое назначил текущий пользователь, или null, если пользователя нет в контактах у текущего пользователя.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" parent="1" vertex="1">
          <mxGeometry x="720" y="710" width="200" height="220" as="geometry" />
        </mxCell>
        <mxCell id="jPiUmuavJyqZ4-y5dbUJ-34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=ERmany;endFill=0;" parent="1" source="QuLFCXCf0gdW-kJHBGHE-37" target="jPiUmuavJyqZ4-y5dbUJ-31" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="540" y="410" as="sourcePoint" />
            <mxPoint x="310" y="105" as="targetPoint" />
            <Array as="points">
              <mxPoint x="550" y="620" />
              <mxPoint x="550" y="555" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
